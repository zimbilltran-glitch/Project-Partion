# ── CTO Security: Never commit secrets or raw API payloads ──────────────────
keys.txt                   # Contains intercepted Fireant Bearer token URLs
fireant_network.json       # Raw Playwright network intercept dump
fireant_network.log        # Bearer token intercept log
fireant_unmatched.log      # Unmatched COA items log
lctt*.json                 # Raw LCTT API response dumps
lctt_dump.json
cdkt.txt                   # Raw debug text
kbsv_items.txt             # Internal API item list
*.log                      # All log files

# ── CTO Security: Encrypted financial data (local-only, never commit) ───────
data/                      # Hive-partitioned encrypted Parquet files
*.parquet                  # Binary financial data

# ── CTO Security: Frontend credentials ─────────────────────────────────────
frontend/.env              # Vite-injected Supabase anon key
frontend/.env.local
frontend/dist/             # Built frontend assets

# ── Large external libraries (not project source) ──────────────────────────
Skill_Testing/             # External skill library (~3000 files)

